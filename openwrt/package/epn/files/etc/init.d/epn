#!/bin/sh /etc/rc.common

START=95
STOP=10
USE_PROCD=1

. /lib/functions.sh
. /lib/functions/procd.sh

PROG=/usr/bin/epn-tun-client

load_epn_config() {
	config_load epn
	config_get_bool enabled main enabled 0
	config_get disc_host main disc_host ""
	config_get disc_port main disc_port 8000
	config_get relays main relays 3
	config_get socks_bind main socks_bind "0.0.0.0"
	config_get socks_port main socks_port 1080
	config_get_bool transparent main transparent 0
	config_get tproxy_port main tproxy_port 1081
	config_get_bool debug main debug 0
}

start_service() {
	load_epn_config
	[ "$enabled" = "1" ] || return 0
	[ -n "$disc_host" ] || return 1
	[ -x "$PROG" ] || return 1

	procd_open_instance
	procd_set_param command "$PROG"
	procd_append_param command --disc-host "$disc_host"
	procd_append_param command --disc-port "$disc_port"
	procd_append_param command --socks-bind "$socks_bind"
	procd_append_param command --socks-port "$socks_port"
	procd_append_param command --relays "$relays"

	if [ "$transparent" = "1" ]; then
		procd_append_param command --transparent
		procd_append_param command --tproxy-port "$tproxy_port"
	fi

	[ "$debug" = "1" ] && procd_append_param command --debug

	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger epn
}

reload_service() {
	stop
	start
}
