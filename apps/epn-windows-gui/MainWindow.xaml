<Window x:Class="Epn.WindowsGui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EPN Client"
        Width="460"
        Height="412"
        MinWidth="420"
        MinHeight="310"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Closing="Window_Closing">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True">
            <Image Width="44" Height="44" Margin="0,0,14,0" Source="Assets/epn.ico"/>
            <StackPanel>
                <TextBlock Text="EPN Client" FontSize="22" FontWeight="SemiBold"/>
                <TextBlock Text="Windows proxy tunnel" Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0"/>
            </StackPanel>
        </DockPanel>

        <StackPanel Grid.Row="2">
            <TextBlock Text="Endpoint URL" FontWeight="SemiBold"/>
            <TextBox x:Name="EndpointBox"
                     Height="34"
                     Margin="0,6,0,0"
                     VerticalContentAlignment="Center"
                     Text="epn://127.0.0.1:8000"/>
        </StackPanel>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Local SOCKS port" FontWeight="SemiBold"/>
                <TextBox x:Name="SocksPortBox"
                         Height="34"
                         Margin="0,6,0,0"
                         VerticalContentAlignment="Center"
                         Text="1080"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Timeout, sec" FontWeight="SemiBold"/>
                <TextBox x:Name="TimeoutBox"
                         Height="34"
                         Margin="0,6,0,0"
                         VerticalContentAlignment="Center"
                         Text="20"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="6"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Ellipse x:Name="StatusDot" Width="14" Height="14" Fill="#94A3B8" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2">
                    <TextBlock x:Name="StatusText" Text="Disconnected" FontWeight="SemiBold"/>
                    <TextBlock x:Name="DetailsText" Text="Enter an endpoint and connect." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Height="35"/>
                </StackPanel>
            </Grid>
        </Border>

        <DockPanel Grid.Row="7" LastChildFill="False" Margin="0,5,0,-5">
            <TextBlock DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource MutedBrush}"
                       FontSize="11"
                       Text="Icon by Icons8"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button x:Name="DisconnectButton"
                        Width="104"
                        Height="36"
                        Margin="0,0,10,0"
                        Content="Disconnect"
                        Click="DisconnectButton_Click"
                        IsEnabled="False"/>
                <Button x:Name="ConnectButton"
                        Width="104"
                        Height="36"
                        Content="Connect"
                        Background="{StaticResource AccentBrush}"
                        Foreground="White"
                        Click="ConnectButton_Click"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
